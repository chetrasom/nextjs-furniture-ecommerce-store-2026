generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id           String     @id @default(uuid())
  name        String
  company     String
  description String
  featured   Boolean
  image       String
  price       Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  clerkId  String

  // # Relation: one Product -> many Favorites
  // # One product can be favorited by many users
  favorites Favorite[]
}

/*====================================================================*/
// # ONE → MANY Model
// # Favorite represents ONE user liking ONE product
// # Each Favorite belongs to:
// - one user (clerkId)
// - one product (productId)
model Favorite {
  id String @id @default(uuid()) // favorite record ID
  clerkId String // user ID from Clek
  productId String // foreign key: links to Product.id

  // This Favorite belongs to ONE Product (linked by productId).
  // If the Product is deleted, this Favorite will be deleted automatically.
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) // when favorite was created
  updatedAt DateTime @updatedAt // last updated timestamp

  // one user can favorite one product only once
  @@unique([clerkId, productId])
}