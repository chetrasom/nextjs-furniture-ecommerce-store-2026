generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id           String     @id @default(uuid())
  name        String
  company     String
  description String
  featured   Boolean
  image       String
  price       Int
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  clerkId  String

  // # Relation: one Product -> many Favorites
  // # One product can be favorited by many users
  favorites Favorite[]

  // # One-to-Many
  // # one product can have many reviews (one-to-many relationship)
  reviews Review []

  cartItems CartItem[]
}

/*====================================================================*/
// # ONE → MANY Model
// # Favorite represents ONE user liking ONE product
// # Each Favorite belongs to:
// - one user (clerkId)
// - one product (productId)
model Favorite {
  id String @id @default(uuid()) // favorite record ID
  clerkId String // user ID from Clek
  productId String // foreign key: links to Product.id

  // This Favorite belongs to ONE Product (linked by productId).
  // If the Product is deleted, this Favorite will be deleted automatically.
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) // when favorite was created
  updatedAt DateTime @updatedAt // last updated timestamp

  // one user can favorite one product only once
  @@unique([clerkId, productId])
}

/*====================================================================*/
// # Review Model
model Review {
  id String @id @default(uuid()) // review record ID
  clerkId  String // ID of the user who wrote the review
  productId String // ID of the related product

  rating Int // rating score (1-5)
  comment String // the review text / comment
  authorName String // name of the reviewer
  authorImageUrl String? // optional image of reviewer

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relation to Product table
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId]) // index for faster lookup by product
}

/*====================================================================*/
// # Cart and CartItem Model
model Cart {
  id        String   @id @default(uuid())
  clerkId  String
  cartItems CartItem[]
  numItemsInCart Int @default(0)
  cartTotal Int @default(0)
  shipping Int @default(5)
  tax Int @default(0)
  taxRate Float @default(0.1)
  orderTotal Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id        String   @id @default(uuid())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String
  cart     Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId   String
  amount  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}